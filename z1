local function getMutationPulseAlpha()
    return (math.sin(os.clock() * CONFIG.MutationPulseSpeed) + 1) * 0.5
end

local function applyMutationPulse(record)
    if not record or not record.Highlight or not record.IsMutated or not record.Highlight.Enabled then
        return
    end

    local fillAlpha = getMutationPulseAlpha()
    local colorAlpha = (math.sin(os.clock() * CONFIG.MutationColorPulseSpeed) + 1) * 0.5
    local secondaryColor = record.MutationSecondaryColor or CONFIG.MutationSafeColor
    local pulseColor = CONFIG.MutationColor:Lerp(secondaryColor, colorAlpha)

    record.Highlight.FillTransparency = CONFIG.MutationFillOutlineOnlyTransparency - ((CONFIG.MutationFillOutlineOnlyTransparency - CONFIG.MutationFillCoveredTransparency) * fillAlpha)
    record.Highlight.OutlineTransparency = CONFIG.MutationOutlineTransparency
    record.Highlight.FillColor = pulseColor
    record.Highlight.OutlineColor = pulseColor
end
local function getHealthText(player, character, humanoid, perkName)
    if not humanoid then
        return "HP: --"
    end

    local baseHealth = roundNumber(humanoid.Health)
    local baseMax = roundNumber(humanoid.MaxHealth)
    local isRogue = typeof(perkName) == "string" and string.lower(perkName) == "rogue"

    if isRogue then
        local resilience = getNumericAttribute(character, {
            "Resilience",
            "CurrentResilience",
            "CurrentShield",
            "RogueShield",
            "Shield",
            "ExcessResilience",
        }) or getNumericAttribute(player, {
            "Resilience",
            "CurrentResilience",
            "CurrentShield",
            "RogueShield",
            "Shield",
            "ExcessResilience",
        }) or 0

        local maxResilience = getNumericAttribute(character, {
            "MaxResilience",
            "MaximumResilience",
            "MaxShield",
            "RogueMaxShield",
        }) or getNumericAttribute(player, {
            "MaxResilience",
            "MaximumResilience",
            "MaxShield",
            "RogueMaxShield",
        }) or resilience

        if resilience > 0 or maxResilience > 0 then
            return string.format("HP: %d/%d + %d/%d", baseHealth, baseMax, roundNumber(resilience), roundNumber(maxResilience))
        end
    end

    return string.format("HP: %d/%d", baseHealth, baseMax)
end

