-- Procedural caution-tape ticker based on the provided black/yellow warning tape image.
-- This avoids requiring a Roblox image asset id; the tape is built from UI frames and scrolls forever.
local exposureTapeMover = Instance.new("Frame")
exposureTapeMover.Name = "ExposureCautionTapeMover"
exposureTapeMover.BackgroundTransparency = 1
exposureTapeMover.BorderSizePixel = 0
exposureTapeMover.Position = UDim2.fromOffset(-CONFIG.CautionTapePeriod, 0)
exposureTapeMover.Size = UDim2.new(1, CONFIG.CautionTapePeriod * 3, 1, 0)
exposureTapeMover.ClipsDescendants = true
exposureTapeMover.ZIndex = 13
exposureTapeMover.Parent = exposureTickerClip

do
    local exposureTapeStroke = Instance.new("UIStroke")
    exposureTapeStroke.Color = Color3.fromRGB(255, 232, 104)
    exposureTapeStroke.Transparency = 0.82
    exposureTapeStroke.Thickness = 1
    exposureTapeStroke.Parent = exposureTickerClip
end

extra.CautionTapeLastWidth = 0
local function rebuildExposureCautionTape()
    if not exposureTapeMover or not exposureTapeMover.Parent then
        return
    end

    local clipWidth = math.max(exposureTickerClip.AbsoluteSize.X, 320)
    local clipHeight = math.max(exposureTickerClip.AbsoluteSize.Y, 18)
    if math.abs(clipWidth - extra.CautionTapeLastWidth) < 4 and #exposureTapeMover:GetChildren() > 0 then
        return
    end
    extra.CautionTapeLastWidth = clipWidth

    for _, child in ipairs(exposureTapeMover:GetChildren()) do
        child:Destroy()
    end

    local period = CONFIG.CautionTapePeriod
    exposureTapeMover.Size = UDim2.fromOffset(clipWidth + (period * 4), clipHeight)

    local yellowBase = Instance.new("Frame")
    yellowBase.Name = "YellowBase"
    yellowBase.BackgroundColor3 = CONFIG.CautionTapeYellow
    yellowBase.BackgroundTransparency = 0
    yellowBase.BorderSizePixel = 0
    yellowBase.Size = UDim2.fromScale(1, 1)
    yellowBase.ZIndex = 13
    yellowBase.Parent = exposureTapeMover

    -- Frame-based stripes create thicker caution marks that run from the top edge to the bottom edge.
    -- The stripe mask clips the rotated black bars so they stay inside the yellow strip.
    local stripeMask = Instance.new("Frame")
    stripeMask.Name = "ContainedStripeMask"
    stripeMask.BackgroundTransparency = 1
    stripeMask.BorderSizePixel = 0
    stripeMask.ClipsDescendants = true
    stripeMask.Size = UDim2.fromScale(1, 1)
    stripeMask.ZIndex = 14
    stripeMask.Parent = exposureTapeMover

    local stripeWidth = CONFIG.CautionTapeStripeWidth
    local stripeHeight = math.max(math.ceil(clipHeight * 2.45), clipHeight + 18)
    local stripeY = -math.ceil((stripeHeight - clipHeight) * 0.5)
    for x = -(period * 2), clipWidth + (period * 6), period do
        local stripe = Instance.new("Frame")
        stripe.Name = "BlackStripe"
        stripe.BackgroundColor3 = CONFIG.CautionTapeBlack
        stripe.BackgroundTransparency = 0
        stripe.BorderSizePixel = 0
        stripe.Position = UDim2.fromOffset(x, stripeY)
        stripe.Size = UDim2.fromOffset(stripeWidth, stripeHeight)
        stripe.Rotation = 17
        stripe.ZIndex = 15
        stripe.Parent = stripeMask
    end
end

connect(exposureTickerClip:GetPropertyChangedSignal("AbsoluteSize"), rebuildExposureCautionTape)
task.defer(rebuildExposureCautionTape)

