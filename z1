    local function findLocalSpeakerController()
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local current = humanoid and humanoid.SeatPart
        while current and current ~= workspace do
            if current:GetAttribute("StrengthSetting") ~= nil
                or current:GetAttribute("IntelligenceSetting") ~= nil
                or current:GetAttribute("AgilitySetting") ~= nil
                or current:GetAttribute("VolumeSetting") ~= nil then
                return current
            end
            current = current.Parent
        end
        return nil
    end

    local function sendSpeakerSettings()
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        local events = remotes and remotes:FindFirstChild("Events")
        local speakerEvent = events and events:FindFirstChild("SpeakerSetting")
        local payload = {
            IntelligenceSetting = tonumber(state.controller.values.IntelligenceSetting) or 0,
            StrengthSetting = tonumber(state.controller.values.StrengthSetting) or 0,
            AgilitySetting = tonumber(state.controller.values.AgilitySetting) or 0,
            VolumeSetting = tonumber(state.controller.volume) or 0,
        }
        for settingName, value in pairs(payload) do
            if value ~= value or value <= -math.huge or value >= math.huge then
                return false, settingName .. " must be a finite number", false
            end
        end

        if not speakerEvent or not speakerEvent:IsA("RemoteEvent") then
            return false, "SpeakerSetting remote unavailable"
        end
        local success, message = pcall(function()
            speakerEvent:FireServer(payload)
        end)
        return success, message, false
    end

