local function syncPatientProxy(record, character)
    if not (record and record.PatientProxy and character) then
        return
    end

    record.PatientProxyParts = record.PatientProxyParts or {}
    local used = {}
    local boxCFrame, boxSize = character:GetBoundingBox()
    local scale = CONFIG.PatientOuterProxyScale

    for _, sourcePart in ipairs(character:GetDescendants()) do
        if shouldUseForPatientProxy(sourcePart) then
            local key = sourcePart.Name
            local proxyPart = record.PatientProxyParts[key]
            if not proxyPart or not proxyPart.Parent then
                proxyPart = createPatientProxyPart("Outer_" .. key, record.PatientProxy)
                record.PatientProxyParts[key] = proxyPart
            end

            local relative = boxCFrame:ToObjectSpace(sourcePart.CFrame)
            local rotationOnly = relative - relative.Position
            proxyPart.Size = Vector3.new(
                math.max(sourcePart.Size.X * scale, 0.05),
                math.max(sourcePart.Size.Y * scale, 0.05),
                math.max(sourcePart.Size.Z * scale, 0.05)
            )
            proxyPart.CFrame = boxCFrame * CFrame.new(relative.Position * scale) * rotationOnly
            proxyPart.Transparency = CONFIG.PatientProxyTransparency
            used[key] = true
        end
    end

    for key, proxyPart in pairs(record.PatientProxyParts) do
        if not used[key] then
            safeDestroy(proxyPart)
            record.PatientProxyParts[key] = nil
        end
    end

    if next(record.PatientProxyParts) == nil then
        local fallback = createPatientProxyPart("Outer_FallbackBody", record.PatientProxy)
        fallback.Size = Vector3.new(
            math.max(boxSize.X * scale, 3.5),
            math.max(boxSize.Y * scale, 5.6),
            math.max(boxSize.Z * scale, 1.8)
        )
        fallback.CFrame = boxCFrame
        record.PatientProxyParts.Outer_FallbackBody = fallback
    end
end

