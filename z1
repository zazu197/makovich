local function positionGraphLine(line, firstPoint, secondPoint)
    local graphSize = extra.AttributeGraph.Frame.AbsoluteSize
    if graphSize.X <= 0 or graphSize.Y <= 0 then
        return
    end

    local windowScale = math.max(state.uiScale or 1, 0.01)
    local logicalGraphSize = Vector2.new(graphSize.X / windowScale, graphSize.Y / windowScale)
    local first = Vector2.new(firstPoint.X.Scale * logicalGraphSize.X, firstPoint.Y.Scale * logicalGraphSize.Y)
    local second = Vector2.new(secondPoint.X.Scale * logicalGraphSize.X, secondPoint.Y.Scale * logicalGraphSize.Y)
    local delta = second - first
    TweenService:Create(line, extra.TweenFast, {
        Position = UDim2.fromOffset((first.X + second.X) * 0.5, (first.Y + second.Y) * 0.5),
        Size = UDim2.fromOffset(delta.Magnitude, 3),
        Rotation = math.deg(math.atan2(delta.Y, delta.X)),
    }):Play()
end

local function updateAttributeGraph()
    local targets = {}
    for index, name in ipairs(extra.AttributeGraph.Order) do
        local pointData = extra.AttributeGraph.Sliders[name]
        local normalized = 0
        if typeof(pointData.Value) == "number" then
            normalized = math.abs(pointData.Value) <= 1 and pointData.Value or (pointData.Value / 100)
        end
        normalized = math.clamp(normalized, -1, 1)
        targets[index] = UDim2.new(pointData.X, 0, 0.5 - (normalized * 0.34), 0)
        pointData.Point.BackgroundTransparency = pointData.Value == nil and 0.62 or 0
        if targets[index].Y.Scale <= 0.26 then
            pointData.ValueLabel.AnchorPoint = Vector2.new(0.5, 0)
            pointData.ValueLabel.Position = UDim2.new(0.5, 0, 1, 6)
        else
            pointData.ValueLabel.AnchorPoint = Vector2.new(0.5, 1)
            pointData.ValueLabel.Position = UDim2.new(0.5, 0, 0, -6)
        end
        TweenService:Create(pointData.Point, extra.TweenFast, { Position = targets[index] }):Play()
    end

    positionGraphLine(extra.AttributeGraph.Lines[1], targets[1], targets[2])
    positionGraphLine(extra.AttributeGraph.Lines[2], targets[2], targets[3])
end

extra.UpdateAttributeGraph = updateAttributeGraph

local function setVerticalSlider(name, value)
    local slider = extra.AttributeGraph.Sliders[name]
    if not slider then
        return
    end

    local nextValue = typeof(value) == "number" and value or nil
    if slider.Value == nextValue then
        return
    end
    slider.Value = nextValue
    slider.ValueLabel.Text = slider.Value == nil and "N/A" or formatReadableValue(slider.Value)
    updateAttributeGraph()
end

