local function getFirstAttributeValue(instances, names)
    local maxIndex = 0
    for key in pairs(instances) do
        if typeof(key) == "number" and key > maxIndex then
            maxIndex = key
        end
    end

    for index = 1, maxIndex do
        local instance = instances[index]
        if instance then
            for _, attributeName in ipairs(names) do
                local ok, value = pcall(function()
                    return instance:GetAttribute(attributeName)
                end)
                if ok and value ~= nil then
                    return value
                end
            end
        end
    end
    return nil
end

local function getFirstNumericAttributeValue(instances, names)
    local value = getFirstAttributeValue(instances, names)
    if typeof(value) == "number" then
        return value
    end
    if typeof(value) == "string" then
        local numeric = tonumber(value)
        if numeric then
            return numeric
        end
    end
    return nil
end

