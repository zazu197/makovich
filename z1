        end)
    else
        local horizontalTween = TweenService:Create(settingsPanel, TweenInfo.new(0.20, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(1, -38, 0, 36),
            Size = UDim2.new(0, 24, 0, 218),
