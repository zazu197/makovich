local function getDistanceScale(distance)
    if typeof(distance) ~= "number" then
        return 1, 0
    end

    if distance >= CONFIG.LabelHideDistance then
        return CONFIG.LabelMinScale, 1
    end

    local sizeAlpha = math.clamp(
        (distance - CONFIG.LabelFullSizeDistance) / math.max(CONFIG.LabelMinSizeDistance - CONFIG.LabelFullSizeDistance, 1),
        0,
        1
    )
    local scale = 1 - ((1 - CONFIG.LabelMinScale) * sizeAlpha)

    local fadeAlpha = math.clamp(
        (distance - CONFIG.LabelFadeStartDistance) / math.max(CONFIG.LabelHideDistance - CONFIG.LabelFadeStartDistance, 1),
        0,
        1
    )

    return scale, fadeAlpha
end

