function extra.UpdateParticleLayer()
    if not state.particlesEnabled or not particleLayer or not particleLayer.Parent then
        if particleLayer then
            particleLayer.Visible = false
        end
        return
    end
    particleLayer.Visible = true

    local absolutePosition = mainFrame.AbsolutePosition
    local absoluteSize = mainFrame.AbsoluteSize
    if absoluteSize.X <= 0 or absoluteSize.Y <= 0 then
        return
    end

    local mouseLocation = UserInputService:GetMouseLocation()
    local mouseLocal = Vector2.new(mouseLocation.X - absolutePosition.X, mouseLocation.Y - absolutePosition.Y)
    local mouseInside = mouseLocal.X >= -80 and mouseLocal.X <= absoluteSize.X + 80
        and mouseLocal.Y >= -80 and mouseLocal.Y <= absoluteSize.Y + 80

    local now = os.clock()
    for index, particle in ipairs(extra.Particles) do
        local frame = particle.Frame
        if frame and frame.Parent then
            local base = seededParticlePosition(index, absoluteSize.X, absoluteSize.Y)
            local drift = Vector2.new(
                math.sin(now * CONFIG.ParticleIdleSpeed + particle.Phase) * 14,
                math.cos(now * (CONFIG.ParticleIdleSpeed * 0.82) + particle.Phase) * 10
            )

            local target = base + drift
            local transparency = 0.18
            local size = (index % 3 == 0) and 3 or 2

            if mouseInside then
                local awayFromMouse = target - mouseLocal
                local distance = awayFromMouse.Magnitude
                if distance < CONFIG.ParticleMouseRadius then
                    local strength = 1 - (distance / CONFIG.ParticleMouseRadius)
                    local pushDirection = distance > 0.001 and awayFromMouse.Unit or particle.Offset.Unit
                    local tangent = Vector2.new(-pushDirection.Y, pushDirection.X)
                    local safeDistance = CONFIG.ParticleMouseRadius * (0.58 + (0.28 * strength))
                    local pushedDistance = math.max(distance + ((CONFIG.ParticleMouseRadius - distance) * 0.96), safeDistance)
                    local ripple = tangent * math.sin(now * 4.4 + index) * 9 * strength
                    target = mouseLocal + (pushDirection * pushedDistance) + ripple
                    transparency = 0.02 + (0.20 * (1 - strength))
                    size = size + (1.7 * strength)
                end
            end

            frame.Position = UDim2.fromOffset(target.X, target.Y)
            frame.Size = UDim2.fromOffset(size, size)
            frame.BackgroundTransparency = transparency
        end
    end
end


function extra.UpdateExposureTicker()
    if not exposureTickerClip or not exposureTickerClip.Parent or not exposureTickerClip.Visible or not checkerPage.Visible then
        return
    end
    rebuildExposureCautionTape()
    local period = math.max(CONFIG.CautionTapePeriod, 1)
    local x = -period + ((os.clock() * CONFIG.CautionTapeScrollSpeed) % period)
    exposureTapeMover.Position = UDim2.fromOffset(x, 0)
end

function extra.BindHoverEffect(object)
    if not object or object:GetAttribute("ModeratorHoverBound") then
        return
    end
    if not (object:IsA("TextButton") or object:IsA("ImageButton") or object:IsA("TextBox")) then
        return
    end
    if object.Name == "ColorWheelInput" or object.Name == "ResizeHandle" or object:GetAttribute("DisabledControl") then
        return
    end

    object:SetAttribute("ModeratorHoverBound", true)

    local scale = object:FindFirstChild("HoverScale") or Instance.new("UIScale")
    scale.Name = "HoverScale"
    scale.Scale = 1
    scale.Parent = object

    local stroke = extra.Navigation.OptionStrokes and extra.Navigation.OptionStrokes[object]
    if not stroke then
        stroke = Instance.new("UIStroke")
        stroke.Name = "HoverStroke"
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.Color = Color3.fromRGB(196, 226, 255)
        stroke.Transparency = 1
        stroke.Thickness = 1
        stroke.Parent = object
    end

    connect(object.MouseEnter, function()
        TweenService:Create(scale, TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Scale = 1.016 }):Play()
        local hoverTransparency = object:GetAttribute("ActivePageOption") and 0.08 or 0.24
        TweenService:Create(stroke, TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Transparency = hoverTransparency }):Play()
    end)

    connect(object.MouseLeave, function()
        TweenService:Create(scale, TweenInfo.new(0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Scale = 1 }):Play()
        local restingTransparency = object:GetAttribute("ActivePageOption") and 0.18 or 1
        TweenService:Create(stroke, TweenInfo.new(0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Transparency = restingTransparency }):Play()
    end)
end

