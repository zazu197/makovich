function extra.ApplyPageLayout()
    if state.minimized then
        return
    end

    local theme = extra.GetCurrentTheme()
    espPage.Visible = state.activePage == "ESP"
    checkerPage.Visible = state.activePage == "CHECKER"
    extra.Controller.Page.Visible = state.activePage == "CONTROLLER"
    extra.Radio.Page.Visible = state.activePage == "RADIO"
    extra.Mutantization.Page.Visible = state.activePage == "MUTANTIZATION"
    extra.Customization.Page.Visible = state.activePage == "CUSTOMIZATION"

    local pageOptions = {
        { Key = "ESP", Label = "ESP", Button = espTab },
        { Key = "CHECKER", Label = "Exposure", Button = checkerTab },
        { Key = "CONTROLLER", Label = "Controller", Button = extra.Controller.Tab },
        { Key = "RADIO", Label = "Radio", Button = extra.Radio.Tab },
        { Key = "MUTANTIZATION", Label = "Mutantization", Button = extra.Mutantization.Tab },
        { Key = "CUSTOMIZATION", Label = "Customization", Button = extra.Customization.Tab },
    }
    for _, option in ipairs(pageOptions) do
        local active = state.activePage == option.Key
        option.Button.BackgroundColor3 = active and CONFIG.AccentBlue or (state.themeMode == "dark" and Color3.fromRGB(55, 65, 81) or theme.SubSurface)
        option.Button.TextColor3 = active and Color3.fromRGB(247, 249, 252) or (state.themeMode == "dark" and Color3.fromRGB(205, 215, 230) or theme.Muted)
        option.Button:SetAttribute("ActivePageOption", active)
        local optionStroke = extra.Navigation.OptionStrokes[option.Button]
        if optionStroke then
            optionStroke.Color = Color3.fromRGB(255, 255, 255)
            optionStroke.Transparency = active and 0.18 or 1
        end
        if active then
            extra.Navigation.Title.Text = option.Label
        end
    end
    title.Text = ""

    if state.activePage == "CHECKER" then
        state.teamDropdownOpen = false
        state.playerDropdownOpen = false
        teamPanel.Visible = false
        playerPanel.Visible = false
        playerDropdownButton.Position = UDim2.new(0, 8, 0, 86)
        TweenService:Create(mainFrame, extra.TweenFast, { Size = extra.WindowSizes.Checker }):Play()
        updateCheckerPanel()
    elseif state.activePage == "CONTROLLER" then
        state.teamDropdownOpen = false
        state.playerDropdownOpen = false
        teamPanel.Visible = false
        playerPanel.Visible = false
        playerDropdownButton.Position = UDim2.new(0, 8, 0, 86)
        TweenService:Create(mainFrame, extra.TweenFast, { Size = extra.WindowSizes.Controller }):Play()
        if extra.Controller.Refresh then
            extra.Controller.Refresh()
        end
    elseif state.activePage == "RADIO" then
        state.teamDropdownOpen = false
        state.playerDropdownOpen = false
        teamPanel.Visible = false
        playerPanel.Visible = false
        playerDropdownButton.Position = UDim2.new(0, 8, 0, 86)
        TweenService:Create(mainFrame, extra.TweenFast, { Size = extra.WindowSizes.Radio }):Play()
        if extra.Radio.Refresh then
            extra.Radio.Refresh()
        end
    elseif state.activePage == "MUTANTIZATION" then
        state.teamDropdownOpen = false
        state.playerDropdownOpen = false
        teamPanel.Visible = false
        playerPanel.Visible = false
        TweenService:Create(mainFrame, extra.TweenFast, { Size = extra.WindowSizes.Mutantization }):Play()
        if extra.Mutantization.Refresh then
            extra.Mutantization.Refresh()
        end
    elseif state.activePage == "CUSTOMIZATION" then
        state.teamDropdownOpen = false
        state.playerDropdownOpen = false
        teamPanel.Visible = false
        playerPanel.Visible = false
        TweenService:Create(mainFrame, extra.TweenFast, { Size = extra.WindowSizes.Customization }):Play()
        if extra.Customization.Refresh then
            extra.Customization.Refresh()
        end
    else
