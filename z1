local function findCheckerPlayer(query)
    query = string.lower((query or ""):gsub("^%s*(.-)%s*$", "%1"))
    if query == "" then
        return nil
    end

    local partialMatch = nil
    for _, player in ipairs(Players:GetPlayers()) do
        local name = string.lower(player.Name or "")
        local displayName = string.lower(player.DisplayName or "")
        if name == query or displayName == query then
            return player
        end
        if not partialMatch and (string.sub(name, 1, #query) == query or string.sub(displayName, 1, #query) == query) then
            partialMatch = player
        end
        if not partialMatch and (string.find(name, query, 1, true) or string.find(displayName, query, 1, true)) then
            partialMatch = player
        end
    end
    return partialMatch
end

local function getHealthLineForChecker(player, character)
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        return "Health: N/A"
    end
    return string.format("Health: %d/%d", roundNumber(humanoid.Health), roundNumber(humanoid.MaxHealth))
end

local function getWeightValue(player, character)
    if player then
        local directWeight = player:GetAttribute("Weight")
        if typeof(directWeight) == "number" then
            return directWeight
        end
        if typeof(directWeight) == "string" then
            local parsedWeight = tonumber(directWeight)
            if parsedWeight then
                return parsedWeight
            end
        end
    end
    return getAttributeStatValue(player, character, CONFIG.WeightAttributeNames)
end

local function formatWeightLine(value)
    if typeof(value) ~= "number" then
        return "Weight: N/A"
    end
    if state.weightUnit == "kg" then
        return string.format("Weight: %.1f kg", value * 0.45359237)
    end
    return string.format("Weight: %.1f lbs", value)
end

local function updateCheckerPanel()
    local query = checkerSearch.Text or ""
    state.checkerQuery = query
    local target = findCheckerPlayer(query)
    state.checkerTarget = target

    if not target then
        checkerNameLabel.Text = query == "" and "No player selected" or "No matching player"
        checkerInfo.Text = query == "" and "Search a player to inspect exposure and mutation data." or "No player matched that name."
        setVerticalSlider("Agility", nil)
        setVerticalSlider("Strength", nil)
        setVerticalSlider("Intelligence", nil)
        weightLabel.Text = "Weight: N/A"
        return
    end

    local character = getCharacterModel(target)
    local exposure = getExposureValue(target, character)
    local mutated = isMutated(target)
    local evolution = getMutationEvolution(target, character)
    local agility = getAttributeStatValue(target, character, CONFIG.AgilityAttributeNames)
    local strength = getAttributeStatValue(target, character, CONFIG.StrengthAttributeNames)
    local intelligence = getAttributeStatValue(target, character, CONFIG.IntelligenceAttributeNames)
    local weight = getWeightValue(target, character)
    local haCount = extra.GetHeartAttackCount(target)

    checkerNameLabel.Text = target.DisplayName ~= target.Name and (target.DisplayName .. " (@" .. target.Name .. ")") or ("@" .. target.Name)
    checkerInfo.Text = table.concat({
        "Exposure: <b>" .. formatExactValue(exposure) .. "</b>",
        getHealthLineForChecker(target, character),
        "Mutated: <b>" .. (mutated and "Yes" or "No") .. "</b>",
        "Evolution: <b>" .. (evolution or "N/A") .. "</b>",
        "HA Counter: <b>" .. tostring(haCount) .. "</b>",
    }, "\n")
    weightLabel.Text = formatWeightLine(weight)
    weightToggleButton.Text = state.weightUnit == "lbs" and "kg" or "lbs"

    setVerticalSlider("Agility", agility)
    setVerticalSlider("Strength", strength)
    setVerticalSlider("Intelligence", intelligence)
end

connect(weightToggleButton.MouseButton1Click, function()
    state.weightUnit = state.weightUnit == "lbs" and "kg" or "lbs"
    weightToggleButton.Text = state.weightUnit == "lbs" and "kg" or "lbs"
    updateCheckerPanel()
end)


