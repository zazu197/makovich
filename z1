    return math.clamp(armor, 0, maxArmor), maxArmor, math.clamp(headArmor, 0, maxHeadArmor), maxHeadArmor
end

function extra.GetHeartAttackCount(player)
    if not player then
        return 0
    end

    local character = getCharacterModel(player)
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health <= 0 then
        state.haScores[player] = 0
        return 0
    end

    local replicatedScore = getFirstNumericAttributeValue({ player }, CONFIG.HeartAttackAttributeNames)
    if typeof(replicatedScore) == "number" then
        return math.clamp(math.floor(replicatedScore + 0.5), 0, 4)
    end

    local localScore = state.haScores[player]
    if typeof(localScore) == "number" then
        return math.clamp(math.floor(localScore + 0.5), 0, 4)
    end

    return 0
end

function extra.SetupHeartAttackWatcher(player)
    if not player then
        return
    end

    if state.haConnections[player] then
        pcall(function()
            state.haConnections[player]:Disconnect()
        end)
        state.haConnections[player] = nil
    end

    local function bindCharacter(character)
        task.spawn(function()
            local humanoid = character and character:WaitForChild("Humanoid", 10)
            if not humanoid then
                return
            end

            local animator = humanoid:FindFirstChildOfClass("Animator") or humanoid:WaitForChild("Animator", 10)
            if not animator then
                return
            end

            if state.haConnections[player] then
                pcall(function()
                    state.haConnections[player]:Disconnect()
                end)
                state.haConnections[player] = nil
            end

            state.haConnections[player] = animator.AnimationPlayed:Connect(function(animationTrack)
                local animation = animationTrack and animationTrack.Animation
                local id = animation and string.match(animation.AnimationId or "", "%d+")
                if id ~= CONFIG.HeartAttackAnimationId or state.haCooldown[player] then
                    return
                end

                local currentScore = extra.GetHeartAttackCount(player)
                if currentScore >= 4 or humanoid.Health <= 0 then
                    return
                end

                state.haCooldown[player] = true
                state.haScores[player] = math.clamp(currentScore + 1, 0, 4)

                task.delay(6, function()
                    if state.haCooldown[player] then
                        state.haCooldown[player] = nil
                    end
                end)

                local stoppedConnection
                stoppedConnection = animationTrack.Stopped:Connect(function()
                    state.haCooldown[player] = nil
                    if stoppedConnection then
                        stoppedConnection:Disconnect()
                    end
                end)
            end)

            humanoid.Died:Connect(function()
                state.haScores[player] = 0
                state.haCooldown[player] = nil
            end)
            connect(humanoid.HealthChanged, function(health)
                if health <= 0 then
                    state.haScores[player] = 0
                    state.haCooldown[player] = nil
                end
            end)
        end)
    end

    player.CharacterAdded:Connect(bindCharacter)
    if player.Character then
        bindCharacter(player.Character)
    end
end

