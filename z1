    mainFrame.BackgroundTransparency = 1
    header.BackgroundTransparency = 1
    content.BackgroundTransparency = 0.04
    extra.Navigation.Container.BackgroundTransparency = math.clamp(0.18 + (transparency * 0.22), 0.20, 0.36)
    extra.Navigation.SelectorButton.BackgroundTransparency = 0.72
    extra.Navigation.Menu.BackgroundTransparency = 1
    enableButton.BackgroundTransparency = 0.08
    teamDropdownButton.BackgroundTransparency = 0.08
    playerDropdownButton.BackgroundTransparency = 0.08
    teamPanel.BackgroundTransparency = 0.08
    playerPanel.BackgroundTransparency = 0.08
    playerSearch.BackgroundTransparency = 0.08
