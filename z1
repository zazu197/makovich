local function refreshPlayerRows()
    clearRows(extra.DropdownRows.players)
    local search = string.lower(state.playerSearchText or "")
    local filtered = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local display = string.lower(player.DisplayName or "")
            local name = string.lower(player.Name or "")
            if search == "" or string.find(display, search, 1, true) or string.find(name, search, 1, true) then
                table.insert(filtered, player)
            end
        end
    end

    table.sort(filtered, function(a, b)
        return string.lower(a.Name) < string.lower(b.Name)
    end)

    for index, player in ipairs(filtered) do
        createPlayerRow(player, index)
    end

    playerScroll.CanvasSize = UDim2.new(0, 0, 0, (#filtered * 34))
    updateDropdownButtonText()
end

