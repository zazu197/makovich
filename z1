local function getSlotOneItem(player)
    local character = player.Character

    local raw = cleanName(getAttributeFromList(player, CONFIG.SlotOneAttributeNames))
        or cleanName(character and getAttributeFromList(character, CONFIG.SlotOneAttributeNames))
        or cleanName(getValueChildFromList(player, CONFIG.SlotOneAttributeNames))
        or cleanName(character and getValueChildFromList(character, CONFIG.SlotOneAttributeNames))

    if raw and not isBlankItemName(raw) then
        return raw, findVisibleToolByName(player, character, raw)
    end

    local dataFolder = player:FindFirstChild("Data")
    if dataFolder then
        raw = cleanName(getAttributeFromList(dataFolder, CONFIG.SlotOneAttributeNames))
            or cleanName(getValueChildFromList(dataFolder, CONFIG.SlotOneAttributeNames))

        if raw and not isBlankItemName(raw) then
            return raw, findVisibleToolByName(player, character, raw)
        end

        for _, child in ipairs(dataFolder:GetChildren()) do
            if table.find(CONFIG.SlotOneAttributeNames, child.Name) and child:IsA("ValueBase") then
                raw = cleanName(child.Value)
                if raw and not isBlankItemName(raw) then
                    return raw, findVisibleToolByName(player, character, raw)
                end
            end
        end
    end

    local visibleTools = getToolsFromContainers(player, character)
    for _, tool in ipairs(visibleTools) do
        if getToolSlot(tool) == 1 then
            return tool.Name, tool
        end
    end

    for _, tool in ipairs(visibleTools) do
        if tool.Parent == character then
            return tool.Name, tool
        end
    end

    return nil, nil
end

local function hasPrm(player)
    local character = player.Character

    if getBoolLike(getAttributeFromList(player, CONFIG.PrmAttributeNames)) then
        return true
    end

    if character and getBoolLike(getAttributeFromList(character, CONFIG.PrmAttributeNames)) then
        return true
    end

    local dataFolder = player:FindFirstChild("Data")
    if dataFolder then
        if getBoolLike(getAttributeFromList(dataFolder, CONFIG.PrmAttributeNames)) then
            return true
        end

        for _, child in ipairs(dataFolder:GetChildren()) do
            if instanceNameMatchesAny(child, CONFIG.PrmNameFragments) then
                if child:IsA("BoolValue") then
                    if child.Value == true then
                        return true
                    end
                elseif child:GetAttribute("HasPerkEquipped") == true or child:GetAttribute("Equipped") == true or child:GetAttribute("Owned") == true then
                    return true
                else
                    return true
                end
            end
        end
    end

    for _, tagName in ipairs(CONFIG.PrmTagNames) do
        local hasTag = false
        pcall(function()
            hasTag = (character and CollectionService:HasTag(character, tagName)) or CollectionService:HasTag(player, tagName)
        end)
        if hasTag then
            return true
        end
    end

    if character then
        for _, descendant in ipairs(character:GetDescendants()) do
            if descendant:IsA("Tool") or descendant:IsA("Accessory") or descendant:IsA("Model") or descendant:IsA("Folder") then
                if instanceNameMatchesAny(descendant, CONFIG.PrmNameFragments) then
                    return true
                end

                local equipmentSlot = descendant:GetAttribute("Char_EquipmentSlot") or descendant:GetAttribute("EquipmentSlot")
                if typeof(equipmentSlot) == "string" and string.lower(equipmentSlot) == "presencereductionmodule" then
                    return true
                end
            end
        end
    end

    local backpack = player:FindFirstChildOfClass("Backpack") or player:FindFirstChild("Backpack")
    if backpack then
        for _, child in ipairs(backpack:GetChildren()) do
            if child:IsA("Tool") and instanceNameMatchesAny(child, CONFIG.PrmNameFragments) then
                return true
            end
        end
    end

    return false
end

