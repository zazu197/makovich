function extra.SetPageMenuOpen(open)
    state.pageMenuOpen = open == true
    state.pageMenuAnimationToken += 1
    local animationToken = state.pageMenuAnimationToken

    extra.Navigation.Container.Size = UDim2.new(0, 176, 1, 0)
    content.Position = UDim2.new(0, 176, 0, 0)
    content.Size = UDim2.new(1, -176, 1, 0)

    if state.pageMenuOpen then
        extra.Navigation.Menu.Visible = true
        extra.Navigation.Menu.Size = UDim2.new(1, -24, 0, 0)
        for _, option in ipairs(extra.Navigation.Options) do
            option.Size = UDim2.new(1, -8, 0, 0)
            option.TextTransparency = 1
            option.BackgroundTransparency = 1
        end
        TweenService:Create(extra.Navigation.Menu, extra.TweenFast, {
            Size = UDim2.new(1, -24, 0, 196),
        }):Play()
        task.spawn(function()
            for _, option in ipairs(extra.Navigation.Options) do
                if animationToken ~= state.pageMenuAnimationToken or not state.pageMenuOpen then
                    return
                end
                TweenService:Create(option, TweenInfo.new(0.16, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = UDim2.new(1, -8, 0, 28),
                    TextTransparency = 0,
                    BackgroundTransparency = 0.76,
                }):Play()
                task.wait(0.045)
            end
        end)
    else
        task.spawn(function()
            for index = #extra.Navigation.Options, 1, -1 do
                if animationToken ~= state.pageMenuAnimationToken or state.pageMenuOpen then
                    return
                end
                local option = extra.Navigation.Options[index]
                TweenService:Create(option, TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                    Size = UDim2.new(1, -8, 0, 0),
                    TextTransparency = 1,
                    BackgroundTransparency = 1,
                }):Play()
                task.wait(0.028)
            end
            if animationToken ~= state.pageMenuAnimationToken or state.pageMenuOpen then
                return
            end
            local closeTween = TweenService:Create(extra.Navigation.Menu, extra.TweenFast, {
                Size = UDim2.new(1, -24, 0, 0),
            })
            closeTween:Play()
            closeTween.Completed:Wait()
            if animationToken == state.pageMenuAnimationToken and not state.pageMenuOpen then
                extra.Navigation.Menu.Visible = false
            end
        end)
    end
end

