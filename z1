local function connect(signal, callback)
    local connection = signal:Connect(callback)
    table.insert(state.connections, connection)
    return connection
end

local function disconnectAll()
    for _, connection in ipairs(state.connections) do
        pcall(function()
            connection:Disconnect()
        end)
    end
    table.clear(state.connections)
end

local function roundNumber(value)
    if typeof(value) ~= "number" then
        return 0
    end
    return math.floor(value + 0.5)
end

local function cleanName(value)
    if typeof(value) == "string" and value ~= "" then
        return value
    end
    if typeof(value) == "number" then
        return tostring(value)
    end
    if typeof(value) == "boolean" then
        return value and "Yes" or "No"
    end
    return nil
end

local function getAttributeFromList(instance, names)
    if not instance then
        return nil
    end

    for _, attributeName in ipairs(names) do
        local value = instance:GetAttribute(attributeName)
        if value ~= nil then
            return value
        end
    end

    return nil
end

local function getValueChildFromList(instance, names)
    if not instance then
        return nil
    end

    for _, childName in ipairs(names) do
        local child = instance:FindFirstChild(childName)
        if child and child:IsA("ValueBase") then
            return child.Value
        end
    end

    return nil
end

local function getNumericAttribute(instance, names)
    if not instance then
        return nil
    end

    for _, attributeName in ipairs(names) do
        local value = instance:GetAttribute(attributeName)
        if typeof(value) == "number" then
            return value
        end
    end

    for _, childName in ipairs(names) do
        local child = instance:FindFirstChild(childName)
        if child and child:IsA("ValueBase") and typeof(child.Value) == "number" then
            return child.Value
        end
    end

    return nil
end

local function getBoolLike(value)
    if value == true then
        return true
    end
    if typeof(value) == "number" then
        return value > 0
    end
    if typeof(value) == "string" then
        local lowered = string.lower(value)
        return lowered == "true" or lowered == "yes" or lowered == "active" or lowered == "equipped" or lowered == "1"
    end
    return false
end

local function instanceNameMatchesAny(instance, fragments)
    if not instance then
        return false
    end

    local lowered = string.lower(instance.Name)
    for _, fragment in ipairs(fragments) do
        if string.find(lowered, fragment, 1, true) then
            return true
        end
    end

    return false
end

local function getTeamColor(player)
    if player.Team then
        local override = CONFIG.TeamColorOverrides[player.Team.Name]
        if override then
            return override
        end
    end

    if player.TeamColor then
        return player.TeamColor.Color
    end

    return Color3.fromRGB(200, 200, 205)
end

local function getTeamKey(player)
    return player.Team and player.Team.Name or "No Team"
end

local function getSelectedCount(dictionary)
    local count = 0
    for _, selected in pairs(dictionary) do
        if selected then
            count += 1
        end
    end
    return count
end

local function shouldShowPlayer(player)
    if player == LocalPlayer then
        return false
    end

    if state.selectedPlayers[player.UserId] then
        return true
    end

    local teamKey = getTeamKey(player)
    if state.selectedTeams[teamKey] then
        return true
    end

    return false
end

local function isNameInList(name, list)
    if typeof(name) ~= "string" then
        return false
    end
    local lowered = string.lower(name)
    for _, expected in ipairs(list) do
        if lowered == string.lower(expected) then
            return true
        end
    end
    return false
end

local function hasCollectionTag(instance, tagName)
    if not instance then
        return false
    end
    local ok, hasTag = pcall(function()
        return CollectionService:HasTag(instance, tagName)
    end)
    return ok and hasTag == true
end

local function hasAnyCollectionTag(instance, tagList)
    if not instance then
        return false
    end
    for _, tagName in ipairs(tagList) do
        if hasCollectionTag(instance, tagName) then
            return true
        end
    end
    return false
end

local function isPatientTeam(player)
    return player and player.Team and isNameInList(player.Team.Name, CONFIG.PatientTeamNames)
end

local function getAttributeFromListOn(instance, names)
    if not instance then
        return nil
    end
    for _, name in ipairs(names) do
        local ok, value = pcall(function()
            return instance:GetAttribute(name)
        end)
        if ok and value ~= nil then
            return value
        end
    end
    return nil
end

local function isPatientAuthorized(player)
    local character = player and player.Character
    local dataFolder = player and player:FindFirstChild("Data")

    if hasAnyCollectionTag(character, CONFIG.PatientAuthorizedTags) or hasAnyCollectionTag(player, CONFIG.PatientAuthorizedTags) then
        return true
    end

    if getBoolLike(getAttributeFromListOn(player, CONFIG.PatientAuthorizedAttributes)) then
        return true
    end
    if getBoolLike(getAttributeFromListOn(character, CONFIG.PatientAuthorizedAttributes)) then
        return true
    end
    if getBoolLike(getAttributeFromListOn(dataFolder, CONFIG.PatientAuthorizedAttributes)) then
        return true
    end

    return false
end

local function isHostilePlayer(player)
    local character = player and player.Character
    local dataFolder = player and player:FindFirstChild("Data")

    if player and player.Team and string.lower(player.Team.Name) == "hostile forces" then
        return true
    end

    if hasAnyCollectionTag(character, CONFIG.HostileTags) or hasAnyCollectionTag(player, CONFIG.HostileTags) then
        return true
    end

    local attrValue = getAttributeFromListOn(character, CONFIG.HostileAttributes)
        or getAttributeFromListOn(player, CONFIG.HostileAttributes)
        or getAttributeFromListOn(dataFolder, CONFIG.HostileAttributes)

    if attrValue == "GlobalTraitor" or attrValue == "Traitor" or attrValue == "Hostile" then
        return true
    end

    return getBoolLike(attrValue) == true
end

local function sortByTeamColorLightToDark(a, b)
    local colorA = a.Color or Color3.fromRGB(200, 200, 205)
    local colorB = b.Color or Color3.fromRGB(200, 200, 205)
    local hA, sA, vA = colorA:ToHSV()
    local hB, sB, vB = colorB:ToHSV()

    if math.abs(vA - vB) > 0.025 then
        return vA > vB
    end
    if math.abs(hA - hB) > 0.01 then
        return hA < hB
    end
    if math.abs(sA - sB) > 0.01 then
        return sA < sB
    end
    return a.Name < b.Name
end

local function lightenColor(color, amount)
    amount = amount or 0.18
    return Color3.new(
        color.R + ((1 - color.R) * amount),
        color.G + ((1 - color.G) * amount),
        color.B + ((1 - color.B) * amount)
    )
end

local function getEquippedPerk(player)
    local character = player.Character or Workspace:FindFirstChild(player.Name)

    local direct = cleanName(getAttributeFromList(player, CONFIG.EquippedPerkAttributeNames))
        or cleanName(character and getAttributeFromList(character, CONFIG.EquippedPerkAttributeNames))

    if direct and direct ~= "None" and direct ~= "0" then
        return direct
    end

    local dataFolder = player:FindFirstChild("Data")
    if dataFolder then
        for _, perkName in ipairs(CONFIG.KnownPerks) do
            local perkObject = dataFolder:FindFirstChild(perkName)
            if perkObject then
                if perkObject:GetAttribute("HasPerkEquipped") == true then
                    return perkName
                end

                if perkObject:IsA("BoolValue") and perkObject.Value == true then
                    return perkName
                end

                local equippedChild = perkObject:FindFirstChild("HasPerkEquipped")
                if equippedChild and equippedChild:IsA("BoolValue") and equippedChild.Value == true then
                    return perkName
                end
            end
        end

        for _, child in ipairs(dataFolder:GetChildren()) do
            if child:GetAttribute("HasPerkEquipped") == true then
                return child.Name
            end

            local equippedChild = child:FindFirstChild("HasPerkEquipped")
            if equippedChild and equippedChild:IsA("BoolValue") and equippedChild.Value == true then
                return child.Name
            end
        end
    end

    return "None"
end

local function getToolsFromContainers(player, character)
    local tools = {}

    local function collect(container)
        if not container then
            return
        end

        for _, child in ipairs(container:GetChildren()) do
            if child:IsA("Tool") then
                table.insert(tools, child)
            end
        end
    end

    collect(character)
    collect(player:FindFirstChildOfClass("Backpack") or player:FindFirstChild("Backpack"))

    return tools
end

local function getToolSlot(tool)
    local rawValue = getAttributeFromList(tool, CONFIG.ToolSlotAttributeNames)
    if rawValue == nil then
        rawValue = getValueChildFromList(tool, CONFIG.ToolSlotAttributeNames)
    end

    if typeof(rawValue) == "number" then
        return rawValue
    end

    if typeof(rawValue) == "string" then
        return tonumber(rawValue)
    end

    return nil
end

local function isBlankItemName(itemName)
    if typeof(itemName) ~= "string" then
        return true
    end

    local cleaned = string.gsub(itemName, "^%s*(.-)%s*$", "%1")
    if cleaned == "" then
        return true
    end

    local lowered = string.lower(cleaned)
    return lowered == "unknown" or lowered == "none" or lowered == "nil" or lowered == "0" or lowered == "empty"
end

local function normalizeItemName(itemName)
    if typeof(itemName) ~= "string" then
        return ""
    end

    local cleaned = string.gsub(itemName, "^%s*(.-)%s*$", "%1")
    cleaned = string.gsub(cleaned, "%s+%[.*%]$", "")
    cleaned = string.gsub(cleaned, "%s+%(.+%)$", "")
    return cleaned
end

local function getWeaponModulesFolder()
    local assets = ReplicatedStorage:FindFirstChild("Assets")
    return assets and assets:FindFirstChild("WeaponModules")
end

local function getWeaponModuleData(itemName)
    local normalized = normalizeItemName(itemName)
    if normalized == "" then
        return nil
    end

    if extra.WeaponModuleCache[normalized] ~= nil then
        return extra.WeaponModuleCache[normalized] or nil
    end

    local modulesFolder = getWeaponModulesFolder()
    if not modulesFolder then
        extra.WeaponModuleCache[normalized] = false
        return nil
    end

    local moduleScript = modulesFolder:FindFirstChild(normalized)
    if not moduleScript then
        local target = string.lower(normalized)
        for _, child in ipairs(modulesFolder:GetChildren()) do
            if child:IsA("ModuleScript") and string.lower(child.Name) == target then
                moduleScript = child
                break
            end
        end
    end

    if not (moduleScript and moduleScript:IsA("ModuleScript")) then
        extra.WeaponModuleCache[normalized] = false
        return nil
    end

    local ok, data = pcall(require, moduleScript)
    if ok and typeof(data) == "table" then
        extra.WeaponModuleCache[normalized] = data
        return data
    end

    extra.WeaponModuleCache[normalized] = false
    return nil
end

local function isDisplayAmmoWeapon(itemName, tool)
    local data = getWeaponModuleData(itemName)
    if data then
        local clipSize = tonumber(data.ClipSize)
        if data.IsEquipment == true then
            return false, data
        end
        if typeof(data.AttackText) == "string" and string.lower(data.AttackText) == "toggle" then
            return false, data
        end
        if typeof(data.ReloadType) == "string" and string.lower(data.ReloadType) == "none" then
            return false, data
        end
        if data.FiringEnabled == false then
            return false, data
        end
        if data.CombatType == "Gun" and clipSize and clipSize > 1 and clipSize < math.huge then
            return true, data
        end
        return false, data
    end

    if tool then
        local current = getNumericAttribute(tool, CONFIG.CurrentAmmoAttributeNames)
        local max = getNumericAttribute(tool, CONFIG.MaxAmmoAttributeNames)
        if current or max then
            return true, nil
        end
    end

    return false, nil
end

local function getAmmoTextForItem(player, itemName, tool)
    if isBlankItemName(itemName) then
        return nil
    end

    local shouldDisplay, data = isDisplayAmmoWeapon(itemName, tool)
    if not shouldDisplay then
        return nil
    end

    local currentAmmo = tool and getNumericAttribute(tool, CONFIG.CurrentAmmoAttributeNames)
    local maxAmmo = tool and getNumericAttribute(tool, CONFIG.MaxAmmoAttributeNames)

    local character = player.Character
    if not currentAmmo and character then
        currentAmmo = getNumericAttribute(character, CONFIG.CurrentAmmoAttributeNames)
    end
    if not maxAmmo and character then
        maxAmmo = getNumericAttribute(character, CONFIG.MaxAmmoAttributeNames)
    end

    if not currentAmmo then
        currentAmmo = getNumericAttribute(player, CONFIG.CurrentAmmoAttributeNames)
    end
    if not maxAmmo then
        maxAmmo = getNumericAttribute(player, CONFIG.MaxAmmoAttributeNames)
    end

    if not maxAmmo and data and tonumber(data.ClipSize) and tonumber(data.ClipSize) < math.huge then
        maxAmmo = tonumber(data.ClipSize)
    end

    if currentAmmo and maxAmmo then
        return string.format("%d/%d", roundNumber(currentAmmo), roundNumber(maxAmmo))
    end

    if currentAmmo then
        return tostring(roundNumber(currentAmmo))
    end

    -- Do not display partial ammo like "?/30".
    -- In this game, the clip size can often be read from weapon modules,
    -- but the live current ammo for other players is usually client-local.
    -- If current ammo is not replicated, show no ammo counter instead.
    return nil
end

