    if extra.Mutantization.Card then
        extra.Mutantization.Card.BackgroundTransparency = 1
    end
    if extra.Customization.Card then
        extra.Customization.Card.BackgroundTransparency = 1
    end
    settingsPanel.BackgroundTransparency = 0.05
    opacityValueLabel.Text = string.format("background transparency: %d%%", math.floor(transparency * 100 + 0.5))
