local function clearTracked(player)
    local record = state.tracked[player]
    if not record then
        return
    end

    for _, object in pairs(record) do
        if typeof(object) == "Instance" then
            safeDestroy(object)
        end
    end

    state.tracked[player] = nil
end

local function setRecordVisible(record, visible)
    if not record then
        return
    end

    if record.Highlight then
        record.Highlight.Enabled = visible
    end
    if record.TopBillboard then
        record.TopBillboard.Enabled = visible
    end
    if record.BottomBillboard then
        record.BottomBillboard.Enabled = visible
    end
    if record.PrmOutline then
        record.PrmOutline.Visible = false
    end
    if record.PrmBox then
        record.PrmBox.Visible = false
    end
end

local function updatePlayerRecord(player)
    if player == LocalPlayer then
        return
    end

    local record = state.tracked[player] or createTracked(player)
    if not shouldShowPlayer(player) then
        setRecordVisible(record, false)
        return
    end
    local character = getCharacterModel(player)
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local root = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso"))
    local head = character and character:FindFirstChild("Head")

    if not state.enabled or not character or not humanoid or humanoid.Health <= 0 or not root then
        setRecordVisible(record, false)
        return
    end

    local localRoot = getLocalRoot()
    local distance = localRoot and (localRoot.Position - root.Position).Magnitude or 0
    local labelScale, fadeAlpha = getDistanceScale(distance)
    local labelsVisible = distance < CONFIG.LabelHideDistance

    local color = getTeamColor(player)
    local mutated = isMutated(player)
    local perkName = getEquippedPerk(player)
    local prmActiveOrEquipped = hasPrm(player)
    local slotOneItem, slotOneTool = getSlotOneItem(player)
    local patientTeam = isPatientTeam(player)
    local patientAuthorized = patientTeam and isPatientAuthorized(player) or false
    local hostileOrUnauthorized = isHostilePlayer(player) or (patientTeam and not patientAuthorized)
    local armor, maxArmor, headArmor, maxHeadArmor = getArmorSnapshot(player, character)

    record.IsMutated = mutated
    record.MutationSecondaryColor = hostileOrUnauthorized and CONFIG.MutationHostileColor or CONFIG.MutationSafeColor
    local primaryHighlightColor = color
    record.Highlight.Adornee = character

    if mutated then
        record.Highlight.FillColor = CONFIG.MutationColor
        record.Highlight.OutlineColor = CONFIG.MutationColor
        record.Highlight.FillTransparency = CONFIG.MutationFillOutlineOnlyTransparency
        record.Highlight.OutlineTransparency = CONFIG.MutationOutlineTransparency
    else
        record.Highlight.FillColor = primaryHighlightColor
        record.Highlight.OutlineColor = primaryHighlightColor
        record.Highlight.FillTransparency = CONFIG.HighlightFillTransparency
        record.Highlight.OutlineTransparency = CONFIG.HighlightOutlineTransparency
    end
    record.Highlight.Enabled = true
    applyMutationPulse(record)

    record.TopBillboard.Adornee = head or root
    record.TopBillboard.Enabled = labelsVisible
    if record.TopScale then
        record.TopScale.Scale = labelScale
    end
    record.HPLabel.Text = getHealthText(player, character, humanoid, perkName)
    record.HPLabel.TextTransparency = fadeAlpha * 0.45
    record.HPLabel.TextStrokeTransparency = 0.42 + (fadeAlpha * 0.45)
    if record.UsernameLabel then
        record.UsernameLabel.Text = "@" .. player.Name
        record.UsernameLabel.TextTransparency = fadeAlpha * 0.50
        record.UsernameLabel.TextStrokeTransparency = 0.42 + (fadeAlpha * 0.45)
    end
    record.PerkLabel.Text = perkName ~= "None" and ("Perk: " .. perkName) or "Perk: None"
    record.PerkLabel.TextColor3 = string.lower(perkName) == "rogue" and CONFIG.RogueColor or CONFIG.MutedTextColor
    record.PerkLabel.TextTransparency = fadeAlpha * 0.55
    record.PerkLabel.TextStrokeTransparency = 0.42 + (fadeAlpha * 0.45)

    local armorAlpha = math.clamp(armor / maxArmor, 0, 1)
    local headArmorAlpha = math.clamp(headArmor / maxHeadArmor, 0, 1)
    record.ArmorFill.Size = UDim2.fromScale(armorAlpha, 1)
    record.HeadArmorFill.Size = UDim2.fromScale(headArmorAlpha, 1)
    record.ArmorLabel.Text = string.format("ARMOR  %d / %d", roundNumber(armor), roundNumber(maxArmor))
    record.HeadArmorLabel.Text = string.format("HELMET  %d / %d", roundNumber(headArmor), roundNumber(maxHeadArmor))
    record.ArmorLabel.TextTransparency = fadeAlpha * 0.55
    record.HeadArmorLabel.TextTransparency = fadeAlpha * 0.55

    local slotText
    if mutated then
        slotText = getMutationEvolution(player, character) or "Mutant"
    else
        slotText = formatSlotOneText(player, slotOneItem, slotOneTool)
    end
    record.BottomBillboard.Adornee = root
    record.BottomBillboard.Enabled = labelsVisible and slotText ~= ""
    if record.BottomScale then
        record.BottomScale.Scale = labelScale
    end
    record.SlotLabel.Text = slotText
    record.SlotLabel.TextTransparency = fadeAlpha * 0.55
    record.SlotLabel.TextStrokeTransparency = 0.42 + (fadeAlpha * 0.45)

    if record.PrmOutline then
        record.PrmOutline.Visible = prmActiveOrEquipped
    end
    local boxCFrame, boxSize = character:GetBoundingBox()

    if record.PrmMarker and prmActiveOrEquipped then
        record.PrmMarker.Size = Vector3.new(
            math.max(boxSize.X + 0.8, 4.2),
            math.max(boxSize.Y + 0.8, 6.3),
            math.max(boxSize.Z + 0.8, 2.4)
        )
        record.PrmMarker.CFrame = boxCFrame
    end

end

local function disableAllRecords()
    for _, record in pairs(state.tracked) do
        setRecordVisible(record, false)
    end
end

