    local function getTracerMuzzlePosition(tool)
        if tool then
            local muzzle = tool:FindFirstChild("Muzzle", true)
            if muzzle then
                if muzzle:IsA("Attachment") then
                    return muzzle.WorldPosition
                end
                if muzzle:IsA("BasePart") then
                    return muzzle.Position
                end
            end
            local handle = tool:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                return handle.Position
            end
        end

        local character = LocalPlayer.Character
        local head = character and character:FindFirstChild("Head")
        if head and head:IsA("BasePart") then
            return head.Position
        end
        local camera = Workspace.CurrentCamera
        return camera and camera.CFrame.Position or Vector3.zero
    end

    local function playTracer(tool)
        if not state.tracer.enabled then
            return
        end

        local mouse = LocalPlayer:GetMouse()
        local targetCFrame = mouse and mouse.Hit
        if not targetCFrame then
            return
        end

        local startPosition = getTracerMuzzlePosition(tool)
        local endPosition = targetCFrame.Position
        local distance = (endPosition - startPosition).Magnitude
        if distance <= 0.1 then
            return
        end

        local tracer = Instance.new("Part")
        tracer.Name = "LocalTracer"
        tracer.Anchored = true
        tracer.CanCollide = false
        tracer.CanTouch = false
        tracer.CanQuery = false
        tracer.CastShadow = false
        tracer.Material = Enum.Material.Neon
        tracer.Color = state.tracer.color
        tracer.Transparency = 0.04
        tracer.Size = Vector3.new(0.1, 0.1, distance)
        tracer.CFrame = CFrame.lookAt(startPosition, endPosition) * CFrame.new(0, 0, -distance / 2)
        tracer.Parent = tracerFolder

        TweenService:Create(tracer, TweenInfo.new(0.45, Enum.EasingStyle.Linear), {
            Transparency = 1,
            Size = Vector3.new(0.02, 0.02, distance),
        }):Play()
        game:GetService("Debris"):AddItem(tracer, 0.55)
    end

    local function bindTracerTool(tool)
        if not (tool and tool:IsA("Tool")) or state.tracer.toolConnections[tool] then
            return
        end
        local connection = tool.Activated:Connect(function()
            playTracer(tool)
        end)
        state.tracer.toolConnections[tool] = connection
        table.insert(state.connections, connection)
    end

    local function scanTracerTools()
        local character = LocalPlayer.Character
        local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
        if character then
            for _, child in ipairs(character:GetChildren()) do
                bindTracerTool(child)
            end
        end
        if backpack then
            for _, child in ipairs(backpack:GetChildren()) do
                bindTracerTool(child)
            end
        end
    end

    local function refreshTracerVisuals()
        local color = state.tracer.color
        colorSwatch.BackgroundColor3 = color
        wheelMarker.BackgroundColor3 = color
        local angle = state.tracer.hue * math.pi * 2
        wheelMarker.Position = UDim2.new(0.5, math.cos(angle) * 58, 0.5, math.sin(angle) * 58)
        colorValue.Text = string.format(
            "RGB  %d  %d  %d",
            math.floor(color.R * 255 + 0.5),
            math.floor(color.G * 255 + 0.5),
            math.floor(color.B * 255 + 0.5)
        )
        for channel, component in pairs({
            Red = color.R,
            Green = color.G,
            Blue = color.B,
        }) do
            local input = extra.Customization.RGBInputs[channel]
            if input and not input:IsFocused() then
                input.Text = tostring(math.floor(component * 255 + 0.5))
            end
        end
        tracerToggle.Text = state.tracer.enabled and "Tracer enabled" or "Tracer disabled"
        tracerToggle.BackgroundColor3 = state.tracer.enabled and CONFIG.AccentBlue or CONFIG.MainSubSurfaceColor
        tracerToggle.TextColor3 = state.tracer.enabled and Color3.fromRGB(245, 248, 252) or CONFIG.MainTextColor
    end

    local function setColorFromPosition(position)
        local center = colorWheel.AbsolutePosition + (colorWheel.AbsoluteSize * 0.5)
        local delta = Vector2.new(position.X, position.Y) - center
        if delta.Magnitude < 18 then
            return
        end
        local hue = (math.atan2(delta.Y, delta.X) / (math.pi * 2)) % 1
        state.tracer.hue = hue
        state.tracer.color = Color3.fromHSV(hue, 0.84, 1)
        refreshTracerVisuals()
    end

    function extra.Customization.ApplyRGB()
        local red = tonumber(extra.Customization.RGBInputs.Red.Text)
        local green = tonumber(extra.Customization.RGBInputs.Green.Text)
        local blue = tonumber(extra.Customization.RGBInputs.Blue.Text)
        if not red or not green or not blue then
            colorValue.Text = "Enter R, G, and B values"
            return
        end

        red = math.clamp(math.floor(red + 0.5), 0, 255)
        green = math.clamp(math.floor(green + 0.5), 0, 255)
        blue = math.clamp(math.floor(blue + 0.5), 0, 255)
        state.tracer.color = Color3.fromRGB(red, green, blue)
        state.tracer.hue = select(1, state.tracer.color:ToHSV())
        refreshTracerVisuals()
    end

    connect(wheelInput.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            state.tracer.draggingColor = true
            setColorFromPosition(input.Position)
        end
    end)
    connect(UserInputService.InputChanged, function(input)
        if state.tracer.draggingColor and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            setColorFromPosition(input.Position)
        end
    end)
    connect(UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            state.tracer.draggingColor = false
        end
    end)
    connect(tracerToggle.MouseButton1Click, function()
        state.tracer.enabled = not state.tracer.enabled
        scanTracerTools()
        refreshTracerVisuals()
    end)
    connect(extra.Customization.RGBApplyButton.MouseButton1Click, extra.Customization.ApplyRGB)
    for _, input in pairs(extra.Customization.RGBInputs) do
        connect(input.FocusLost, function(enterPressed)
            if enterPressed then
                extra.Customization.ApplyRGB()
            end
        end)
    end

    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack") or LocalPlayer:WaitForChild("Backpack", 10)
    if backpack then
        connect(backpack.ChildAdded, bindTracerTool)
    end
    connect(LocalPlayer.CharacterAdded, function(character)
        connect(character.ChildAdded, bindTracerTool)
        task.defer(scanTracerTools)
    end)
    if LocalPlayer.Character then
        connect(LocalPlayer.Character.ChildAdded, bindTracerTool)
    end

    scanTracerTools()
    refreshTracerVisuals()
    extra.Customization.Refresh = refreshTracerVisuals
end

