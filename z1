    end
end)

connect(UserInputService.InputChanged, function(input)
    if not state.resizingWindow or not state.resizeDragStart or not state.resizeStartSize or not state.resizeStartWindowPosition then
        return
    end
    if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
        return
    end

    local delta = input.Position - state.resizeDragStart
    local horizontalDelta = delta.X / math.max(state.resizeStartSize.X, 1)
    local verticalDelta = delta.Y / math.max(state.resizeStartSize.Y, 1)
    local resizeDelta = math.abs(horizontalDelta) >= math.abs(verticalDelta) and horizontalDelta or verticalDelta
    if horizontalDelta * verticalDelta > 0 and math.abs(horizontalDelta) > 0.002 and math.abs(verticalDelta) > 0.002 then
        resizeDelta = (horizontalDelta + verticalDelta) * 0.5
    end
    state.uiScale = math.clamp(state.resizeStartScale * (1 + resizeDelta), 0.65, 1.50)
    local unscaledStartWidth = state.resizeStartSize.X / math.max(state.resizeStartScale, 0.01)
    local horizontalShift = ((unscaledStartWidth * state.uiScale) - state.resizeStartSize.X) * 0.5
    mainFrame.Position = UDim2.new(
        state.resizeStartWindowPosition.X.Scale,
        state.resizeStartWindowPosition.X.Offset + horizontalShift,
        state.resizeStartWindowPosition.Y.Scale,
        state.resizeStartWindowPosition.Y.Offset
    )
    extra.WindowScale.Scale = state.uiScale
end)


