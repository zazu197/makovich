local function getSortedTeams()
    local byName = {}
    for _, team in ipairs(game:GetService("Teams"):GetTeams()) do
        byName[team.Name] = { Name = team.Name, Color = team.TeamColor.Color }
    end

    for _, player in ipairs(Players:GetPlayers()) do
        local name = getTeamKey(player)
        if not byName[name] then
            byName[name] = { Name = name, Color = getTeamColor(player) }
        end
    end

    local teams = {}
    for _, info in pairs(byName) do
        table.insert(teams, info)
    end
    table.sort(teams, sortByTeamColorLightToDark)
    return teams
end

