    local armor = getFirstNumericAttributeValue(sources, CONFIG.ArmorAttributeNames) or 0
    local maxArmor = math.min(getFirstNumericAttributeValue(sources, CONFIG.MaxArmorAttributeNames) or 75, 75)
    local headArmor = getFirstNumericAttributeValue(sources, CONFIG.HeadArmorAttributeNames) or 0
    local maxHeadArmor = math.min(getFirstNumericAttributeValue(sources, CONFIG.MaxHeadArmorAttributeNames) or 60, 60)

    maxArmor = math.max(maxArmor, 1)
