function extra.RevealSettingsText()
    local revealIndex = 0
    for _, descendant in ipairs(extra.SettingsContent:GetDescendants()) do
        if descendant:IsA("TextLabel") or descendant:IsA("TextButton") or descendant:IsA("TextBox") then
            revealIndex += 1
            descendant.TextTransparency = 1
            local textObject = descendant
            task.delay((revealIndex - 1) * 0.018, function()
                if state.settingsOpen and textObject.Parent then
                    TweenService:Create(textObject, TweenInfo.new(0.24, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {
                        TextTransparency = 0,
                    }):Play()
                end
            end)
        end
    end
end

